# ─── Database ────────────────────────────────────────────────────────────────
POSTGRES_DB=affiliate_intelligence
POSTGRES_USER=aip_user
POSTGRES_PASSWORD=aip_secret
DATABASE_URL=postgresql://aip_user:aip_secret@localhost:5432/affiliate_intelligence
# Run migrations: alembic upgrade head

# ─── ChromaDB ────────────────────────────────────────────────────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_TOKEN=chroma_secret_token

# ─── OpenAI / LangChain ──────────────────────────────────────────────────────
OPENAI_API_KEY=placeholder
OPENAI_MODEL=gpt-4o-mini
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=

# ─── Embedding model (local, no API cost) ────────────────────────────────────
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ─── App ─────────────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
API_SECRET_KEY=change-me-in-production
ALLOWED_ORIGINS=http://localhost:8080,http://localhost:3000

# ─── ML model artefacts ──────────────────────────────────────────────────────
MODEL_DIR=models/

# ─── S3 / S3-compatible model storage ────────────────────────────────────────
# Set USE_S3=true to persist models across deployments
USE_S3=false
S3_BUCKET=your-bucket-name
S3_MODEL_PREFIX=models/
# Leave S3_ENDPOINT_URL empty for AWS S3
# DigitalOcean Spaces: https://nyc3.digitaloceanspaces.com
# Cloudflare R2:       https://<acct>.r2.cloudflarestorage.com
# Backblaze B2:        https://s3.us-west-002.backblazeb2.com
S3_ENDPOINT_URL=
AWS_ACCESS_KEY_ID=your-key
AWS_SECRET_ACCESS_KEY=your-secret
AWS_DEFAULT_REGION=eu-west-2
