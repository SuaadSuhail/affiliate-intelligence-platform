# ─── Database ────────────────────────────────────────────────────────────────
POSTGRES_DB=affiliate_intelligence
POSTGRES_USER=aip_user
POSTGRES_PASSWORD=aip_secret
DATABASE_URL=postgresql://aip_user:aip_secret@localhost:5432/affiliate_intelligence

# ─── ChromaDB ────────────────────────────────────────────────────────────────
CHROMA_HOST=localhost
CHROMA_PORT=8001
CHROMA_TOKEN=chroma_secret_token

# ─── OpenAI / LangChain ──────────────────────────────────────────────────────
OPENAI_API_KEY=sk-...your-key-here...
OPENAI_MODEL=gpt-4o
LANGCHAIN_TRACING_V2=false
LANGCHAIN_API_KEY=

# ─── Embedding model (local, no API cost) ────────────────────────────────────
EMBEDDING_MODEL=sentence-transformers/all-MiniLM-L6-v2

# ─── App ─────────────────────────────────────────────────────────────────────
APP_ENV=development
LOG_LEVEL=INFO
API_SECRET_KEY=change-me-in-production

# ─── ML model artefacts ──────────────────────────────────────────────────────
MODEL_DIR=models/
CHURN_MODEL_PATH=models/churn_model.json
GROWTH_MODEL_PATH=models/growth_model.json
